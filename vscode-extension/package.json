{
  "name": "koh",
  "displayName": "koh",
  "description": "Attach to koh tmux sessions from VS Code",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "koh.attach",
        "title": "koh: Attach to session"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
